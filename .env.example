# Copy this to .env for local development
# NEVER commit .env to GitHub

# Required
DATABASE_URL=postgresql+asyncpg://user:password@localhost/weatherarb

# Bot identity (required by NOAA TOS)
USER_AGENT=WeatherArbBot/1.0 your@email.com

# Paper trading settings
STARTING_BANKROLL=2000.0
DRY_RUN=true

# Edge thresholds (optional — defaults in config.py)
MIN_EDGE=0.08
MIN_CONFIDENCE=0.68
MIN_VOLUME=50000
